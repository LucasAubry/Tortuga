[sub_resource type="Shader" id="5"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

uniform sampler2D normal_texture : filter_linear_mipmap_anisotropic, repeat_enable;
uniform vec4 color_deep : source_color = vec4(0.005, 0.05, 0.15, 1.0);
uniform vec4 color_shallow : source_color = vec4(0.04, 0.4, 0.55, 1.0);
uniform float wave_speed : hint_range(0.0, 5.0) = 0.5;
uniform float wave_strength : hint_range(0.0, 2.0) = 0.7;

varying float v_height;
varying vec3 v_world_pos;

vec3 get_wave(vec2 uv, float t, float weight, float wavelength, float speed, vec2 dir) {
    float k = 2.0 * PI / wavelength;
    float f = k * (dot(normalize(dir), uv) - t * speed);
    float a = (weight * wave_strength) / k;
    float h = sin(f) * 0.5 + 0.5;
    h = h * h; 
    return vec3(normalize(dir).x * a * cos(f) * 0.25, weight * h, normalize(dir).y * a * cos(f) * 0.25);
}

void vertex() {
    v_world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
    float t = TIME * wave_speed;
    
    vec3 w = vec3(0.0);
    w += get_wave(v_world_pos.xz, t, 1.2, 140.0, 0.5, vec2(1.0, 0.2));
    w += get_wave(v_world_pos.xz, t, 0.7, 85.0, 0.8, vec2(-0.8, 0.4));
    w += get_wave(v_world_pos.xz, t, 0.3, 35.0, 1.5, vec2(0.5, -0.7));
    
    v_height = w.y;
    VERTEX += w;
}

void fragment() {
    // Smooth geometric base
    vec3 pixel_normal = normalize(cross(dFdy(v_world_pos), dFdx(v_world_pos)));
    
    float t = TIME * 0.025;
    
    // EXPLAIN: Richer Texture layering
    // We add more visible normal detail to create those \"glints\" and \"ripples\" that catch the light
    vec2 uv_ripple = v_world_pos.xz * 0.06;
    vec3 n1 = texture(normal_texture, uv_ripple + vec2(t * 0.6, t * 1.2)).rgb * 2.0 - 1.0;
    vec3 n2 = texture(normal_texture, uv_ripple * 0.5 - vec2(t * 1.5, -t * 0.4)).rgb * 2.0 - 1.0;
    vec3 detail_normal = normalize(n1 + n2);
    
    // Slightly more influence from the normal map to make the texture visible
    vec3 final_normal = normalize(pixel_normal + detail_normal * 0.12);
    
    float fresnel = pow(1.0 - dot(final_normal, VIEW), 3.0);
    vec3 ocean_color = mix(color_deep.rgb, color_shallow.rgb, clamp(fresnel + (v_height * 0.1), 0.0, 1.0));
    
    // Peak Foam (Slightly more descriptive)
    float foam = smoothstep(1.4, 3.5, v_height + (n1.x * 0.2));
    ocean_color = mix(ocean_color, vec3(0.95, 1.0, 1.0), foam * 0.45);
    
    ALBEDO = ocean_color;
    NORMAL = final_normal;
    METALLIC = 0.05;
    ROUGHNESS = 0.06;
    SPECULAR = 0.6;
}

void light() {
    float dot_nl = clamp(dot(NORMAL, LIGHT), 0.0, 1.0);
    vec3 light_influence = LIGHT_COLOR * ATTENUATION;
    
    vec3 H = normalize(VIEW + LIGHT);
    float dot_nh = clamp(dot(NORMAL, H), 0.0, 1.0);
    
    // EXPLAIN: Enhanced Sunlight Trail & Glints
    // By sharpening the specular and adding a bit more intensity, 
    // the texture detail we added above will catch the sun brilliantly.
    float spec = pow(dot_nh, 256.0) * 1.5; // Sharp glints
    float shine = pow(dot_nh, 32.0) * 0.4; // Broad shine
    
    // Darken shadows even more for contrast
    vec3 diffuse = ALBEDO * dot_nl * 0.5;
    
    SPECULAR_LIGHT += (shine + spec) * light_influence;
    DIFFUSE_LIGHT += diffuse * light_influence;
}"

