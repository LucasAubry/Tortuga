[sub_resource type="Shader" id="Shader_water"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

uniform vec4 albedo : source_color = vec4(0.0, 0.45, 0.75, 1.0);
uniform vec4 albedo2 : source_color = vec4(0.0, 0.25, 0.55, 1.0);
uniform float metallic : hint_range(0.0, 1.0) = 0.0;
uniform float roughness : hint_range(0.0, 1.0) = 0.02;
uniform float wave_speed : hint_range(0.0, 5.0) = 0.5;
uniform float wave_amplitude : hint_range(0.0, 5.0) = 1.0;
uniform float wave_frequency : hint_range(0.0, 5.0) = 0.1;

uniform vec2 island_1 = vec2(150.0, 150.0);
uniform vec2 island_2 = vec2(-150.0, 150.0);
uniform vec2 island_3 = vec2(150.0, -150.0);
uniform vec2 island_4 = vec2(-150.0, -150.0);

varying vec2 world_pos;

void vertex() {
	// Simple sine wave displacement for the water surface
	float time = TIME * wave_speed;
	float wave1 = sin(VERTEX.x * wave_frequency + time) * wave_amplitude;
	float wave2 = cos(VERTEX.z * wave_frequency * 1.5 + time * 1.2) * wave_amplitude * 0.8;
	
	// Distance to closest island for wave dampening
	float d1 = distance(VERTEX.xz, island_1);
	float d2 = distance(VERTEX.xz, island_2);
	float d3 = distance(VERTEX.xz, island_3);
	float d4 = distance(VERTEX.xz, island_4);
	float min_d = min(min(d1, d2), min(d3, d4));
	
	// Smoothstep from 45.0m to 120.0m (waves are flat until 45m away, then rise to full at 120m)
	float dampen = smoothstep(45.0, 120.0, min_d);
	
	VERTEX.y += (wave1 + wave2) * dampen;
	world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xz;
}

void fragment() {
	// Mix color based on height/time to give it a nice gradient
	float time = TIME * wave_speed * 0.5;
	float wave_mask = sin(UV.x * 20.0 + time) * cos(UV.y * 20.0 + time) * 0.5 + 0.5;
	
	vec3 base_color = mix(albedo.rgb, albedo2.rgb, wave_mask);
	
	// Add Isometric Grid
	float grid_size = 100.0;
	vec2 grid_uv = fract(world_pos / grid_size);
	float line_width = 0.02; // Thin grid lines
	float grid_mask = step(grid_uv.x, line_width) + step(grid_uv.y, line_width);
	grid_mask = clamp(grid_mask, 0.0, 1.0);
	
	ALBEDO = mix(base_color, vec3(0.0, 0.6, 1.0), grid_mask * 0.15);
	// No alpha write forces it to be opaque and write to depth buffer for Cel Shader masking
	
	METALLIC = metallic;
	ROUGHNESS = roughness;
}"

