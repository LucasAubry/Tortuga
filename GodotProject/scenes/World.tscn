[sub_resource type="Shader" id="5"]
code = "shader_type spatial;
render_mode blend_mix, depth_draw_opaque, cull_back, diffuse_burley, specular_schlick_ggx;

uniform sampler2D normal_texture : filter_linear_mipmap_anisotropic, repeat_enable;
uniform vec4 color_deep : source_color = vec4(0.01, 0.05, 0.1, 1.0);
uniform vec4 color_shallow : source_color = vec4(0.05, 0.45, 0.6, 1.0);
uniform float map_width = 2400.0;
uniform float map_height = 3600.0;

varying vec3 v_world_pos;

void vertex() {
    v_world_pos = (MODEL_MATRIX * vec4(VERTEX, 1.0)).xyz;
}

void fragment() {
    float half_w = map_width * 0.5;
    float half_h = map_height * 0.5;
    if (abs(v_world_pos.x) > half_w || abs(v_world_pos.z) > half_h) {
        discard;
    }

    vec3 pixel_normal = vec3(0.0, 1.0, 0.0);
    float t = TIME * 0.1;
    
    // Ondulations très subtiles (réduit pour éviter le blanc)
    vec2 uv_ripple = v_world_pos.xz * 0.05;
    vec3 n1 = texture(normal_texture, uv_ripple + vec2(t)).rgb * 2.0 - 1.0;
    vec3 n2 = texture(normal_texture, uv_ripple * 0.5 - vec2(t * 0.8)).rgb * 2.0 - 1.0;
    vec3 final_normal = normalize(pixel_normal + (n1 + n2) * 0.1);
    
    // Dégradé Bleu sur Bleu
    float dist = length(v_world_pos.xz) / (half_w * 1.5);
    float grad = clamp(dist, 0.0, 1.0);
    
    // On force des bleus bien saturés
    vec3 shallow = vec3(0.05, 0.35, 0.6); // Cyan/Bleu vif
    vec3 deep = vec3(0.01, 0.05, 0.15);   // Bleu nuit
    vec3 ocean_color = mix(shallow, deep, grad);
    
    // Fresnel très discret (juste pour le relief, pas de blanc)
    float fresnel = pow(1.0 - dot(pixel_normal, VIEW), 5.0);
    ocean_color = mix(ocean_color, vec3(0.1, 0.4, 0.8), fresnel * 0.3);
    
    ALBEDO = ocean_color;
    NORMAL = final_normal;
    METALLIC = 0.0;
    ROUGHNESS = 0.5; // Rugosité haute pour capter les ombres sans briller
    SPECULAR = 0.1;
}
"

